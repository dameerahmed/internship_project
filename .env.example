# ==========================================
# Dameer Webhook Gateway - Env Configuration
# ==========================================

# --- Databases & Services (Docker Container Hosts) ---
# In Docker, we use the container names ('db', 'redis', 'rabbitmq') as hostnames.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/internship_db
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://admin:admin123@rabbitmq:5672/

# --- Database Container Init Config ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=internship_db

# --- Security ---
SECRET_KEY=dev-secret-key-change-in-production-1234567890
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=False

# --- Asymmetric Signature Signing (Optional, run python backend/run.py to generate) ---
SYSTEM_PRIVATE_KEY=""
SYSTEM_PUBLIC_KEY=""

# --- Port Bindings (Host ports) ---
FRONTEND_PORT=80
BACKEND_PORT=8000
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
REDIS_PORT=6379
POSTGRES_PORT=5432

